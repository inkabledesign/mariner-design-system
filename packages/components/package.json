{
  "name": "@inkabledesign/mariner-components",
  "version": "1.0.2",
  "type": "module",
  "description": "Cross-platform React Native components for Mariner applications",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "react-native": "index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "atoms",
    "molecules",
    "organisms",
    "templates",
    "hooks",
    "types",
    "data"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "echo \"No tests for components package\"",
    "lint": "echo \"No linting for components package\""
  },
  "dependencies": {
    "@inkabledesign/mariner-assets": "file:../assets"
  },
  "peerDependencies": {
    "@inkabledesign/mariner-theme": "*",
    "expo-image": "~55.0.0",
    "nativewind": "^4.0.0",
    "react": "^19.0.0",
    "react-native": "^0.83.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^4.0.0",
    "react-native-safe-area-context": "^5.0.0",
    "react-native-svg": "^15.0.0",
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "expo-image": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "rollup": "^4.6.0",
    "typescript": "^5.2.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inkabledesign/mariner-design-system.git",
    "directory": "packages/components"
  }
}
