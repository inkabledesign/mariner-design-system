{
  "expo": {
    "name": "Mariner Mobile Storybook",
    "slug": "mariner-mobile-storybook",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mariner.storybook"
    },
    "android": {
      "package": "com.mariner.storybook"
    },
    "scheme": "mariner-storybook",
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ]
    ]
  }
}
